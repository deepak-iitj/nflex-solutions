# Contact form: enquiries are sent to Info@ivamationsolutions.com
# Get your free access key at https://web3forms.com (use Info@ivamationsolutions.com as recipient)
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Product datasheets (Vercel Blob). Base URL of your blob store (no trailing slash).
# Optional: fallback is /datasheets/dummy-datasheet.pdf
VITE_BLOB_STORAGE_BASE_URL=https://your-store.private.blob.vercel-storage.com

# Server-side only (API / uploads): do not use VITE_ prefix. Set in Vercel Environment Variables.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
